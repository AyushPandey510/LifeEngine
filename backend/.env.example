# Environment Configuration Template
# Copy this to .env and fill in your actual values

# Application
ENVIRONMENT=development
SECRET_KEY=your-256-bit-random-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Database (PostgreSQL)
# Local development can use either DATABASE_URL or the individual POSTGRES_* values.
# Render Postgres provides DATABASE_URL automatically in render.yaml.
# DATABASE_URL=postgresql://lifeengine:your-secure-password@localhost:5433/lifeengine
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=lifeengine
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=lifeengine

# Redis
# Local development can use either REDIS_URL or the individual REDIS_* values.
# Render Key Value provides REDIS_URL automatically in render.yaml.
# REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
FAISS_DIR=local_faiss_indexes

# AI / LLM APIs (Groq)
GROQ_API_KEY=gsk-your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=60

# Embeddings for RAG. If omitted in development, deterministic local test
# vectors are used; production should configure an embedding provider.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Email (optional - for verification emails)
# RESEND_API_KEY=re_your-resend-api-key
# FROM_EMAIL=hello@lifeengine.ai

# Payments (optional)
# RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRET=xxx
