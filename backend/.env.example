# Environment Configuration Template
# Copy this to .env and fill in your actual values

# Application
ENVIRONMENT=development
SECRET_KEY=your-256-bit-random-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lifeengine
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=lifeengine

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# AI / LLM APIs
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google Gemini (optional - recommended for free tier)
# Get your API key from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# Email (optional - for verification emails)
# RESEND_API_KEY=re_your-resend-api-key
# FROM_EMAIL=hello@lifeengine.ai

# Payments (optional)
# RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRET=xxx